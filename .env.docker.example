# Tajni ključevi za Authelia — svaki mora biti nasumičan niz, min. 32 znaka
# Generiranje: openssl rand -hex 32

AUTHELIA_SESSION_SECRET=zamijeni_s_nasumicnim_nizom_32_znaka
AUTHELIA_STORAGE_ENCRYPTION_KEY=zamijeni_s_nasumicnim_nizom_32_znaka
AUTHELIA_JWT_SECRET=zamijeni_s_nasumicnim_nizom_32_znaka

# Lozinka AD service accounta (npr. svc-croris)
AUTHELIA_LDAP_PASSWORD=lozinka_service_accounta
